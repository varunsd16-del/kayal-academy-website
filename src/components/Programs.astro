---
const programs = [
 {
  title: "Indian Abacus",
  description: "Our complete 8-level Indian Abacus program develops mental math speed, concentration, memory, and confidence in children aged 5–14.",
  image: "/courses/indian-abacus-classes-trichy.webp",
  class: "abacus-img",
  note: "Authorized Indian Abacus Franchise",
  features: ["Mental Arithmetic", "Speed Calculation", "Improves Memory", "Boosts Concentration"],
  link: "/courses"
},
  {
    title: "Calligraphy & Handwriting",
    description: "Transform your child's handwriting into beautiful calligraphy. We focus on proper grip, stroke consistency, and artistic lettering.",
    features: ["Improves Legibility", "Boosts Confidence", "Enhances Motor Skills", "Artistic Expression"],
    image: "/courses/calligraphy-handwriting-classes-trichy.webp",
    link: "/courses"
  },
  {
    title: "School Tuitions (1st to 8th Std)",
    description: "Comprehensive coaching for school students from 1st to 8th standard across major boards. We ensure strong foundational knowledge and exam readiness.",
    features: ["Personalized Attention", "Regular Assessments", "Expert Faculty", "Concept Clearing"],
    image: "/courses/school-tuitions-grade-1-to-8-trichy.webp",
    link: "/courses"
  },
  {
    title: "Hindi Language Classes",
    description: "Master the national language with our structured Hindi courses. Perfect for beginners or school students needing academic support.",
    features: ["Reading & Writing", "Spoken Fluency", "Grammar Mastery", "School Syllabus Help"],
    image: "/courses/spoken-hindi-classes-trichy.webp",
    link: "/courses"
  },
  {
    title: "Phonics (E Planet)",
    description: "Authorized by E Planet Learning, our Phonics classes build a strong foundation in reading, pronunciation, and vocabulary for early learners.",
    features: ["Sound Recognition", "Fluent Reading", "Spelling Accuracy", "Confidence Building"],
    image: "/courses/eplanet-phonics-classes-trichy.webp",
    link: "/courses"
  },
  {
    title: "Vedic Maths",
    description: "Ancient Indian mathematical techniques that empower students to solve complex calculations mentally with lightning speed and accuracy.",
    features: ["Mental Calculation", "Speed Math Tricks", "Competitive Exam Prep", "Eliminates Math Fear"],
    image: "/courses/vedic-maths-classes-trichy.webp",
    link: "/courses"
  },
  {
    title: "Chess (Summer Class)",
    description: "Engaging summer program to learn chess strategies. Boosts critical thinking, problem-solving skills, and concentration in a fun environment.",
    features: ["Strategic Thinking", "Problem Solving", "Focus & Patience", "Summer Special"],
    image: "/courses/summer-chess-classes-trichy.webp",
    link: "/courses"
  }
];
---

<section id="programs" class="programs-section section">

  <!-- Elegant asymmetric SVG divider -->
  <div class="custom-shape-divider-top">
    <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
        <path d="M985.66,92.83C906.67,72,823.78,31,743.84,14.19c-82.26-17.34-168.06-16.33-250.45.39-57.84,11.73-114,31.07-172,41.86A600.21,600.21,0,0,1,0,27.35V0H1200V86.59C1132.19,118.92,1055.71,111.31,985.66,92.83Z" class="shape-fill"></path>
    </svg>
  </div>
 
  <div class="container">
    <div class="text-center section-header reveal">
      <span class="badge text-primary" style="background: rgba(6, 95, 70, 0.08); border-color: rgba(6, 95, 70, 0.2);">Authorized Franchise</span>

      <h2 class="h2 reveal delay-100">
        Best Tuition Center in <span class="text-accent">Trichy</span>
      </h2>
      <p class="text-lg subtitle mx-auto text-muted reveal delay-200">As an <strong class="text-primary">Authorized Indian Abacus Franchise</strong>, Kayal Academy offers the best Abacus classes in Trichy along with handwriting,
phonics, Hindi classes and school tuition programs for children aged 5–14.
    </div>

    <div class="programs-grid">
      {programs.map((program, index) => (
        <a href={program.link} class={`course-card reveal delay-${(index % 3) * 100}`} aria-label={`Learn more about ${program.title} at Kayal Academy`}>
          {/* Top visual graphic with actual images */}
          <div class="card-thumbnail">
            <img src={program.image} alt={program.title} class={`course-thumbnail-img ${program.class || ""}`} />
            <div class="thumbnail-overlay"></div>
          </div>
          
          {/* Main content body */}
          <div class="card-body">
            <div class="card-meta">
              <span class="meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Flexible
              </span>
              <span class="meta-rating">
                <span class="stars">★★★★★</span>
                <span class="score">5.0</span>
              </span>
            </div>
            
            <h3 class="course-title">{program.title}</h3>

{program.note && (
  <span class="course-note">{program.note}</span>
)}
            
          </div>
          
          {/* Footer with Instructor & Category */}
          <div class="card-footer">
            <div class="instructor">
              <div class="avatar-circle">
                <img src="/achievements/logo.webp" alt="Kayal Academy Logo" />
              </div>
              <div class="instructor-info">
                <span class="name">Kayal Academy</span>
                <span class="role">Certified Instructor</span>
              </div>
            </div>
            <span class="category-btn">{program.features[0].split(' ')[0]}</span>
          </div>
        </a>
      ))}
    </div>
    
    <!-- Central Floating Action Button -->
    <div class="full-curriculum-action reveal delay-500">
      <a href="/courses" class="btn btn-primary btn-pill shadow-glow">View Full Curriculum</a>
    </div>
  </div>
</section>


<style>
  .programs-section {
    background-color: transparent;
    position: relative;
    padding-top: 4rem; /* Adjusted padding to tighten spacing */
    padding-bottom: 6rem;
    z-index: 2;
  }
  
  .programs-section::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(to right, transparent, rgba(16, 185, 129, 0.3), transparent);
  }

  /* Custom Shape Divider */
  .custom-shape-divider-top {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }

  .custom-shape-divider-top svg {
    position: relative;
    display: block;
    width: calc(100% + 1.3px);
    height: 90px;
    transform: rotateY(180deg);
  }

  .custom-shape-divider-top .shape-fill {
    fill: var(--color-bg); /* Match the background of the section above */
  }

  .section-header {
    max-width: 800px;
    margin: 0 auto 4rem;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: var(--radius-full);
    margin-bottom: 1rem;
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(10px);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .subtitle {
    margin-top: 1rem;
    max-width: 600px;
  }

  .text-primary { color: var(--color-primary); }
  .text-accent { color: var(--color-primary-light); }
  .text-muted { color: var(--color-text-muted); }
  .mx-auto { margin-left: auto; margin-right: auto; }

  .programs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Exact Course Card Style from Reference */
  .course-card {
    background: #ffffff;
    border-radius: 1.25rem;
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 0, 0, 0.03);
    transition: all 0.3s ease;
  }

  .course-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
  }

  /* Image Thumbnail Header */
 .card-thumbnail {
  aspect-ratio: 16 / 9;
  width: 100%;
  overflow: hidden;
  position: relative;
  background: #f8fafc; /* light background so image looks clean */
  display: flex;
  align-items: center;
  justify-content: center;
}



.course-thumbnail-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
}
.abacus-img {
  object-position: center 40%;
}
  .course-card:hover .course-thumbnail-img {
    transform: scale(1.08); /* Zoom effect on hover */
  }

  /* Overlay gradient so the image isn't too stark and blends slightly */
  .thumbnail-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 50%, rgba(0,0,0,0.1) 100%);
    pointer-events: none;
  }

  /* Middle Body */
  .card-body {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-text-muted);
  }

  .meta-rating {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .stars {
    color: #fbbf24;
    letter-spacing: 1px;
    font-size: 0.85rem;
  }

  .score {
    color: var(--color-text-muted);
  }

  .course-title {
    font-family: var(--font-family-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.4;
    margin: 0;
  }

  /* Bottom Footer */
  .card-footer {
    padding: 1.25rem 1.5rem;
    border-top: 1px solid rgba(0,0,0,0.06);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .course-note {
  font-size: 0.72rem;
  color: var(--color-primary);
  font-weight: 600;
  margin-top: 4px;
}
  .instructor {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .avatar-circle {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.05);
  }
@media (max-width: 768px) {
  .programs-grid {
    grid-template-columns: 1fr;
    max-width: 450px;
    margin: 0 auto;   /* ensures perfect center */
  }
}
  .avatar-circle img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 2px;
  }

  .instructor-info {
    display: flex;
    flex-direction: column;
  }

  .instructor-info .name {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .instructor-info .role {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .category-btn {
    padding: 0.35rem 0.85rem;
    background: rgba(16, 185, 129, 0.1);
    color: var(--color-primary-dark);
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 100px;
  }

  /* Floating Action Button (View Full Curriculum) */
  .full-curriculum-action {
    display: flex;
    justify-content: center;
    margin-top: 3rem; /* Intersects with the row above */
    position: relative;
    z-index: 20;
    padding-bottom: 2rem;
  }

  .btn-pill {
    padding: 1rem 2.5rem;
    border-radius: 999px;
    font-weight: 700;
    letter-spacing: 0.05em;
    font-size: 0.95rem;
  }

  .shadow-glow {
    box-shadow: 0 10px 25px -5px rgba(16, 185, 129, 0.4);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .shadow-glow:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 35px -5px rgba(16, 185, 129, 0.5);
  }

  @media (max-width: 1024px) {
    .programs-grid {
      grid-template-columns: repeat(2, 1fr); 
    }
  }

  @media (max-width: 768px) {
    .programs-grid {
      grid-template-columns: 1fr;
      max-width: 450px;
    }
  }
</style>
