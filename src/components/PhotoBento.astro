---
const bentoCards = [
  { 
    images: ["/achievements/kayal-academy-graduation-ceremony-1.webp", "/achievements/kayal-academy-graduation-ceremony-2.webp", "/achievements/national-abacus-olympiad-winner-2.webp", "/achievements/abacus-training-trichy-hero.webp"], 
    span: "row-span-2 col-span-2",
    alt: "Graduation ceremony at Kayal Academy Trichy"
  },
  { 
    images: ["/achievements/student-feedback-kayal-academy-2.webp", "/achievements/abacus-class-students-trichy.webp", "/achievements/rising-star-abacus-award.webp", "/achievements/abacus-training-session-teppakulam.webp"], 
    span: "row-span-1 col-span-1",
    alt: "Abacus training session at Teppakulam tuition centre"
  },
  { 
    images: ["/achievements/national-abacus-olympiad-winner-1.webp", "/achievements/regional-abacus-olympiad-winner.webp", "/achievements/mental-math-prodigies-trichy.webp", "/achievements/kayal-academy-about-us-1.webp"], 
    span: "row-span-1 col-span-1",
    alt: "Mental math prodigies showcase"
  },
  { 
    images: ["/achievements/kayal-academy-community-outreach-1.webp", "/achievements/kayal-academy-community-outreach-2.webp", "/achievements/kayal-academy-about-us-2.webp", "/achievements/student-feedback-kayal-academy-1.webp"], 
    span: "row-span-1 col-span-2",
    alt: "Community outreach programs by Kayal Academy"
  }
];
---

<section class="photo-bento section">
  <div class="container">
    <div class="bento-header text-center mb-12 reveal">
      <span class="badge glass">Campus Life</span>
      <h2 class="h2 mt-4 font-heading text-primary reveal delay-100">Experience the Academy</h2>
    </div>
    
    <div class="bento-grid">
      {bentoCards.map((card, i) => (
        <div class={`bento-item ${card.span} glass reveal reveal-scale delay-${(i % 4) * 100} photo-carousel`}>
          {card.images.map((url, imgIndex) => (
            <img 
              src={url} 
              alt={card.alt} 
              loading={imgIndex === 0 ? "eager" : "lazy"} 
              class={`carousel-img ${imgIndex === 0 ? 'active' : ''}`} 
            />
          ))}
          <div class="bento-overlay"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .photo-bento {
    background-color: var(--color-surface);
    padding: 6rem 0;
    position: relative;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.5);
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .font-heading { font-family: var(--font-family-heading); }
  .text-primary { color: var(--color-primary); }
  .mb-12 { margin-bottom: 4rem; }
  .mt-4 { margin-top: 1rem; }
  .text-center { text-align: center; }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 250px;
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .bento-item {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: var(--transition-slow);
    box-shadow: 0 10px 30px -10px var(--color-shadow);
  }

  .bento-item img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1s ease-in-out, transform 0.7s ease;
  }

  .bento-item img.active {
    opacity: 1;
    z-index: 1;
  }

  .bento-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(4, 120, 87, 0.4), transparent 50%);
    opacity: 0;
    transition: var(--transition);
    z-index: 2;
  }

  .bento-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px -10px var(--color-shadow), 0 0 0 4px rgba(16, 185, 129, 0.2);
  }

  .bento-item:hover img.active {
    transform: scale(1.05);
  }

  .bento-item:hover .bento-overlay {
    opacity: 1;
  }

  .row-span-2 { grid-row: span 2; }
  .col-span-2 { grid-column: span 2; }
  .col-span-1 { grid-column: span 1; }
  .row-span-1 { grid-row: span 1; }

  @media (max-width: 900px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 200px;
    }
  }

  @media (max-width: 600px) {
    .bento-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 250px;
    }
    .col-span-2 { grid-column: span 1; }
    .row-span-2 { grid-row: span 1; }
  }
</style>

<script>
  function initPhotoCarousels() {
    const carousels = document.querySelectorAll('.photo-carousel');
    
    carousels.forEach(carousel => {
      const images = carousel.querySelectorAll('.carousel-img');
      if (images.length <= 1) return;
      
      // Clear existing interval if any (for HMR / ViewTransitions safety)
      if (carousel instanceof HTMLElement && carousel.dataset.intervalId) {
        clearInterval(Number(carousel.dataset.intervalId));
      }
      
      let currentIndex = 0;
      // Faster, more noticeable delay
      const intervalDelay = 2500 + Math.random() * 500;
      
      const intervalId = setInterval(() => {
        // Find current active
        images.forEach(img => img.classList.remove('active'));
        
        // Move to next
        currentIndex = (currentIndex + 1) % images.length;
        images[currentIndex].classList.add('active');
      }, intervalDelay);
      
      if (carousel instanceof HTMLElement) {
        carousel.dataset.intervalId = intervalId.toString();
      }
    });
  }

  // Run exactly once on initial load, and hook into page-load for transitions
  initPhotoCarousels();
  document.addEventListener('astro:page-load', initPhotoCarousels);
</script>
