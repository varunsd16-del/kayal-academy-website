---
interface Props {
  isExtended?: boolean;
}

const { isExtended = false } = Astro.props;
const achievements = [
  { value: 3, suffix: "+", label: "Years Experience" },
  { value: 200, suffix: "+", label: "Total Students" },
  { value: 98, suffix: "%", label: "Success Rate" },
  { value: 4, suffix: "+", label: "Certified Trainers" }
];
---

<section id="about" class="about-me section">
  <img src="/achievements/logo.webp" alt="Kayal Academy Logo" class="watermark-bg" />
  <div class="container">
    <div class="about-grid">
      
      <!-- Image Column -->
      <div class="about-image-column reveal reveal-left">
        <div class="image-wrapper clip-style">
          <img 
            src="/achievements/kayal-academy-about-us-1.webp" 
            alt="Kayal founder of Kayal Academy Abacus and mental math training centre in Trichy"
            class="founder-img"
          />
          <div class="accent-frame"></div>
        </div>
        
        <div class="image-wrapper clip-style-reverse second-img reveal reveal-scale delay-100">
          <img 
            src="/achievements/kayal-academy-about-us-2.webp" 
            alt="Kayal Academy Trichy - Students and Instructor" 
            class="founder-img"
            loading="lazy"
          />
          <div class="accent-frame" style="transform: rotate(3deg); bottom: -1rem; right: -2rem; left: auto; opacity: 0.1;"></div>
        </div>
      </div>

      <!-- Content Column -->
      <div class="about-content">
        <span class="badge text-primary reveal" style="background: rgba(15, 118, 110, 0.08); border-color: rgba(15, 118, 110, 0.2);">Meet the founders of Kayal Academy</span>
        <h2 class="h2 mb-4 reveal delay-100">Why Parents Trust <span class="text-accent">Kayal Academy</span></h2>
        
        <div class="prose reveal delay-200">
          <p>
            Kayal Academy is one of the leading Abacus training centers in Trichy located
            in Teppakulam. We specialize in Indian Abacus programs designed to improve
            children's mental math skills, concentration, memory power, and confidence.
            Our academy also provides handwriting improvement classes, phonics training,
            spoken Hindi classes, and school tuition support for students from grade 1 to 8.
          </p>
          <p>
            Welcome to Kayal Academy, Trichy's leading Abacus and mental math training centre and academic excellence. Founded by visionary educators <strong>Mrs.S.Kayalvizhi BE</strong>, we are proud to be an <strong class="text-primary">Authorized Indian Abacus Franchise Center</strong>. Our Teppakulam tuition centre has established itself as the gold standard in education over the last decade.
          </p>
          <p>
            Mrs.S.Kayalvizhi BE have championed a radically different approach to schooling. Whether it's mastering mental arithmetic through the official Indian Abacus program, perfecting cursive handwriting, or excelling in CBSE/State board examinations, their certified team delivers reliable, tangible results.
          </p>
        </div>

        <div class="founder-profile card glass reveal delay-250 mt-6 profile-padding">
          <h3 class="h4 font-heading text-primary mb-3">Mrs.S.Kayalvizhi BE</h3>
          <ul class="qualifications-list text-muted text-sm qualification-space">
            <li class="qualification-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-accent qualification-icon"><polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Diploma in Instrumentation & Control Engineering, Seshasayee Institute of Technology, Trichy</span>
            </li>
            <li class="qualification-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-accent qualification-icon"><polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Bachelor of Engineering (Instrumentation & Control Engineering)</span>
            </li>
            <li class="qualification-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-accent qualification-icon"><polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Diploma in Calligraphy, Bishop Heber College</span>
            </li>
            <li class="qualification-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-accent qualification-icon"><polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Graduated in Abacus, Indian Abacus</span>
            </li>
          </ul>
        </div>

        <div class={`achievements-section ${isExtended ? 'mt-4' : 'mt-8'} reveal delay-${isExtended ? 400 : 300}`}>
          <h3 class="h4 font-heading mb-4 text-primary">Our Achievements</h3>
          <div class="achievements-grid">
            {achievements.map((item, index) => (
              <div class={`achievement-card delay-${(index % 4) * 100}`}>
                <div 
  class="achievement-value text-accent font-heading counter"
  data-target={item.value}
  data-suffix={item.suffix}
>
  0
</div>
                <div class="achievement-label text-sm text-muted">{item.label}</div>
              </div>
            ))}
          </div>
        </div>

        {!isExtended && (
          <a href="/about" class="btn btn-primary mt-8 reveal delay-400">Read Our Full Story</a>
        )}
      </div>

    </div>
  </div>
</section>

<script>
function initCounters() {
  const counters = document.querySelectorAll(".counter");

  const observer = new IntersectionObserver((entries, obs) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;

      const counter = entry.target;
      const target = parseInt(counter.dataset.target);
      const suffix = counter.dataset.suffix || "";

      let start = null;
      const duration = 1200; // faster (1.2 seconds)

      function animate(timestamp) {
        if (!start) start = timestamp;
        const progress = Math.min((timestamp - start) / duration, 1);

        const value = Math.floor(progress * target);
        counter.textContent = value + suffix;

        if (progress < 1) {
          requestAnimationFrame(animate);
        } else {
          counter.textContent = target + suffix;
        }
        /* small numbers show instantly */
if (target <= 10) {
  counter.textContent = target + suffix;
  obs.unobserve(counter);
  return;
}
      }

      requestAnimationFrame(animate);
      obs.unobserve(counter);
    });
  }, { threshold: 0.4 });

  counters.forEach(counter => observer.observe(counter));
}

// Run on first load
document.addEventListener("DOMContentLoaded", initCounters);

// Run after Astro page navigation
document.addEventListener("astro:page-load", initCounters);
</script>

<style>
  .about-me {
    background-color: var(--color-bg-alt); /* slightly inset color for contrast */
    padding: 8rem 0;
    position: relative;
    z-index: 20;
    margin-top: -6rem; /* Asymmetrical overlap layout pulling into upper section */
    overflow: hidden;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 6rem;
    align-items: center;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: var(--radius-full);
    margin-bottom: 1.5rem;
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(10px);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .text-primary { color: var(--color-primary); }
  .text-accent { color: var(--color-primary-light); }
  .text-muted { color: var(--color-text-muted); }
  .font-heading { font-family: var(--font-family-heading); }
  
  .mb-4 { margin-bottom: 1.5rem; }
  .mt-8 { margin-top: 3rem; }

  /* Image styling (Clipped) */
  .about-image-column {
    position: relative;
    padding-left: 2rem;
    padding-bottom: 2rem;
    margin-top: -8rem; /* Stems further up for editorial feel */
  }

  .clip-style {
    clip-path: polygon(10% 0, 100% 0, 100% 90%, 90% 100%, 0 100%, 0 10%); /* Elegant chamfered edge cut */
    border-radius: 0;
  }
  /* Reverse corner style for second image */
.clip-style-reverse {
  clip-path: polygon(10% 0, 100% 0, 100% 90%, 90% 100%, 0 100%, 0 10%); /* Elegant chamfered edge cut */
  border-radius: 0;
}
  .second-img{
  margin-top: 4rem;
  margin-left: 2.5rem;
}
  .founder-img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    box-shadow: 0 30px 60px -15px var(--color-shadow);
    position: relative;
    z-index: 2;
    transition: var(--transition-slow);
  }
  
  .founder-img:hover {
    transform: scale(1.02);
  }

  .accent-frame {
    position: absolute;
    bottom: -2rem;
    left: -2rem;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    border-radius: 2rem;
    z-index: 1;
    opacity: 0.15;
    transform: rotate(-3deg);
    transition: var(--transition-slow);
  }
  
  .image-wrapper:hover .accent-frame {
    transform: rotate(-5deg) scale(1.05);
    opacity: 0.25;
  }

  /* Content */
  .prose p {
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
    color: var(--color-text-muted);
    text-align: justify;
  }

  /* Achievements */
  .achievements-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .achievement-card {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(10px);
    padding: 1.5rem;
    border-radius: var(--radius-md);
    border-left: 4px solid var(--color-primary-light);
    border-top: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    transition: var(--transition);
  }
  
  .achievement-card:hover {
    transform: translateX(5px);
    background: white;
    box-shadow: 0 10px 20px -5px var(--color-shadow);
  }

  .achievement-value {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 0.5rem;
    transition: transform .3s ease;
  }

  .achievement-label {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  /* Founder Profile Styles */
  .profile-padding {
    padding: 1.5rem;
  }
  
  .qualification-space {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  
  .qualification-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    line-height: 1.5;
  }
  
  .qualification-icon {
    margin-top: 0.125rem;
    flex-shrink: 0;
    min-width: 16px;
  }

  /* Watermark image */
  .watermark-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60vw;
    max-width: 800px;
    opacity: 0.03;
    z-index: 0;
    pointer-events: none;
  }

  @media (max-width: 992px) {
    .about-grid {
      display: flex;
      flex-direction: column;
      gap: 4rem;
    }
    .about-image-column {
      order: 1;
      max-width: 500px;
      margin: 0 auto;
      padding-left: 1rem;
      padding-bottom: 1rem;
      margin-top: 0;
    }
    .about-content {
      order: 2;
    }
    .about-me { margin-top: 0; }
    .accent-frame {
      bottom: -1rem;
      left: -1rem;
      border-radius: 0; /* Match clip */
    }
    .hidden-mobile {
      display: none !important;
    }
  }
  @media (max-width: 768px){

  .second-img{
    margin-left: 0;
    margin-top: 2rem;
  }

}
  @media (max-width: 600px) {
    .achievements-grid {
      grid-template-columns: 1fr;
    }
    .watermark-bg { width: 90vw; }
  }

</style>
