---
---

<section class="trust-section">
  <div class="container trust-grid">

    <!-- Logo -->
    <div class="trust-logo">
      <div class="logo-card">
        <img 
          src="/achievements/kayal-foundation-trust.webp"
          alt="Kayal Foundation Educational Trust"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Content -->
    <div class="trust-content">

      <span class="trust-badge">Educational Trust</span>

      <h2>
        Kayal Foundation <span>Educational Trust</span>
      </h2>

      <p>
        Kayal Academy operates under the guidance of 
        <strong>Kayal Foundation Educational Trust</strong>, which is dedicated
        to supporting quality education and learning initiatives.
      </p>

      <p>
        The trust also provides educational support to students <strong class="text-black">
        who cannot afford learning opportunities</strong>, helping them continue their education
      and build a better future.
      </p>

    </div>

  </div>
</section>


<style>

.trust-section{
  padding: clamp(4rem, 6vw, 7rem) 0;
  background: linear-gradient(180deg,#ffffff 0%, #f9fafb 100%);
}

.trust-grid{
  display:grid;
  grid-template-columns: minmax(220px,320px) 1fr;
  gap: clamp(2rem,4vw,4rem);
  align-items:center;
}

/* Logo */

.trust-logo{
  display:flex;
  justify-content:center;
}

.logo-card{
  background:white;
  padding:28px;
  border-radius:18px;
  box-shadow:0 15px 40px rgba(0,0,0,0.06);
  transition:all .3s ease;
}

.logo-card:hover{
  transform:translateY(-6px);
  box-shadow:0 20px 50px rgba(0,0,0,0.1);
}

.logo-card img{
  width:160px;
  display:block;
}

/* Badge */

.trust-badge{
  display:inline-block;
  background:rgba(16,185,129,.12);
  color:var(--color-primary);
  padding:6px 14px;
  border-radius:999px;
  font-size:.8rem;
  font-weight:600;
  margin-bottom:14px;
}

/* Heading */

.trust-content h2{
  font-size: clamp(1.6rem,2vw,2.1rem);
  font-weight:700;
  margin-bottom:18px;
}

.text-black{
  color:#6b7280;
  font-weight:700;

}

.trust-content strong:not(.text-black){
  color:var(--color-primary);
}

/* Text */

.trust-content p{
  color:var(--color-text-muted);
  line-height:1.8;
  margin-bottom:14px;
  max-width:650px;
}


/* Tablet */

@media(max-width:900px){

.trust-grid{
  grid-template-columns:1fr;
  text-align:center;
}

.trust-content p{
  margin-left:auto;
  margin-right:auto;
}

}

/* Mobile */

@media(max-width:600px){

.logo-card{
  padding:22px;
}

.logo-card img{
  width:140px;
}

}

</style>