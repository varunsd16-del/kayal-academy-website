</div
  <!-- Main content -->
  <div class="container relative z-10">
    <div class="text-center mb-12 reveal">
      <span class="badge text-primary" style="background: rgba(15, 118, 110, 0.08); border-color: rgba(15, 118, 110, 0.2);">The Kayal Difference</span>
      <h2 class="h2 mb-4 mt-4">Why We Stand <span class="text-accent">Apart</span></h2>
      <p class="text-muted max-w-2xl mx-auto">
        Most tuition centres focus on rote memorization. At Kayal Academy in Teppakulam, Trichy, our Abacus training and skill development programs are designed to build deep conceptual understanding instead of simple memorization.
      </p>
    </div>

    <div class="methodology-grid">
      <div class="methodology-visual-col reveal reveal-left">
        <div class="methodology-visual shadow-glow">
          <img
            src="/1.jpeg"
            alt="Students practicing Indian Abacus training at Kayal Academy in Teppakulam, Trichy"
            class="methodology-img"
          />
        </div>
      </div>

      <div class="methodology-content reveal delay-200">
        <h3 class="h3 font-heading text-primary mb-4">Beyond the Syllabus – Smart Learning at Kayal Academy</h3>
        <p class="text-muted mb-6 leading-relaxed">
          While ordinary tuition centers rush to finish the syllabus, we prioritize foundational clarity. By strengthening core concepts before moving ahead, our students naturally solve advanced problems faster and with far greater confidence than their peers.
        </p>
        <h3 class="h3 font-heading text-primary mb-4">Focus Driven Assessment</h3>
        <p class="text-muted mb-6 leading-relaxed">
          Unlike crowded classrooms where students get lost in the noise, our model involves continuous, individualized assessments. Every child receives targeted micro-adjustments to their learning approach—from optimizing pencil grip during calligraphy to refining mental imagery during Abacus calculation.
        </p>

        <div class="features-list mt-8">
          <div class="feature-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-accent feature-icon"><polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="font-heading">100% Core Competence</span>
          </div>
          <div class="feature-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-accent feature-icon"><polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="font-heading">Zero Rote Learning</span>
          </div>
          <div class="feature-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-accent feature-icon"><polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="font-heading">Individual Growth Mapping</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .bg-muted-light {
    background-color: rgba(243, 244, 246, 0.5);
    border-top: 1px solid rgba(0,0,0,0.05);
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }

  .mb-12 { margin-bottom: 3rem; }
  .mt-4  { margin-top: 1rem; }
  .mt-8  { margin-top: 2rem; }
  .mb-4  { margin-bottom: 1rem; }
  .mb-6  { margin-bottom: 1.5rem; }
  .text-center { text-align: center; }
  .mx-auto { margin-left: auto; margin-right: auto; }
  .max-w-2xl { max-width: 42rem; }
  .leading-relaxed { line-height: 1.8; text-align: justify; }
  .relative  { position: relative; }
  .overflow-hidden { overflow: hidden; }
  .z-10 { z-index: 10; }

  /* ── Scattered decorative icons ── */
  .deco-icon {
    position: absolute;
    z-index: 1;
    pointer-events: none;
    opacity: 0.09;
    transition: opacity 0.5s ease;
    animation-name: drift;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
  }

  .deco-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  @keyframes drift {
    0%, 100% { translate: 0 0px; }
    50%       { translate: 0 -7px; }
  }

  .methodology-section:hover .deco-icon {
    opacity: 0.14;
  }

  /* ── Badge ── */
  .badge {
    display: inline-block;
    padding: 0.4rem 1.2rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-full);
    border: 1px solid transparent;
  }

  /* ── Layout ── */
  .methodology-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    margin-top: 3rem;
  }

  .methodology-visual {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .methodology-img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
    transition: var(--transition-slow);
  }

  .methodology-visual:hover .methodology-img {
    transform: scale(1.03);
  }

  .shadow-glow {
    box-shadow: 0 20px 40px -10px rgba(15, 118, 110, 0.2);
  }

  .features-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.05rem;
    color: var(--color-text);
  }
 .icons-wrapper{
  position:absolute;
  inset:0;
  width:100%;
  max-width:1600px;
  margin:auto;
  pointer-events:none;
}
  .feature-icon {
    background: rgba(212, 175, 55, 0.1);
    border-radius: 50%;
    padding: 0.25rem;
    width: 28px;
    height: 28px;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .methodology-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .methodology-visual-col {
      max-width: 700px;
      margin: 0 auto;
      width: 100%;
    }
    /* hide inner icons, keep 4 corners */
    .deco-icon.inner { display: none; }
  }

 @media (max-width: 640px) {

  /* Hide all icons first */
  .deco-icon{
    display:none;
  }

  /* Show only corner icons */
  .deco-icon:nth-child(1),
  .deco-icon:nth-child(2),
  .deco-icon:nth-child(3),
  .deco-icon:nth-child(4){
    display:block;
    width:55px !important;
    opacity:0.06;
  }

}
  
</style>
