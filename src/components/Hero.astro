---
import { Image } from 'astro:assets';

const heroImage = "/achievements/abacus-training-trichy-hero.webp"; 
---

<section class="hero overflow-hidden relative min-h-screen flex items-center">
  <!-- Glowing Background Ambience -->
  <div class="glow glow-1"></div>
  <div class="glow glow-2"></div>
  <div class="texture-overlay"></div>

  <!-- Educational Doodles -->
  <div class="doodles-layer" aria-hidden="true">
    <!-- Abacus -->
    <svg class="doodle d1" viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <rect x="10" y="10" width="60" height="60" rx="4"/>
      <line x1="10" y1="25" x2="70" y2="25"/>
      <line x1="10" y1="40" x2="70" y2="40"/>
      <line x1="10" y1="55" x2="70" y2="55"/>
      <circle cx="25" cy="25" r="4"/><circle cx="40" cy="25" r="4"/><circle cx="55" cy="25" r="4"/>
      <circle cx="30" cy="40" r="4"/><circle cx="50" cy="40" r="4"/>
      <circle cx="20" cy="55" r="4"/><circle cx="35" cy="55" r="4"/><circle cx="55" cy="55" r="4"/>
    </svg>

    <!-- Pi -->
    <svg class="doodle d2" viewBox="0 0 50 50" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M10 15 h30 M18 15 v22 M32 15 v18 q0 6-5 6"/>
    </svg>

    <!-- Plus -->
    <svg class="doodle d3" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <line x1="20" y1="8" x2="20" y2="32"/>
      <line x1="8" y1="20" x2="32" y2="20"/>
    </svg>

    <!-- Multiply -->
    <svg class="doodle d4" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <line x1="10" y1="10" x2="30" y2="30"/>
      <line x1="30" y1="10" x2="10" y2="30"/>
    </svg>

    <!-- Sigma -->
    <svg class="doodle d5" viewBox="0 0 50 60" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M38 10 H15 L28 30 L15 50 H38"/>
    </svg>

    <!-- Square root -->
    <svg class="doodle d6" viewBox="0 0 50 50" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 35 L15 35 L22 45 L35 10 L45 10"/>
    </svg>

    <!-- Divide -->
    <svg class="doodle d7" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <circle cx="20" cy="10" r="3" fill="currentColor"/>
      <line x1="8" y1="20" x2="32" y2="20"/>
      <circle cx="20" cy="30" r="3" fill="currentColor"/>
    </svg>

    <!-- Pencil -->
    <svg class="doodle d8" viewBox="0 0 50 50" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M35 5 L45 15 L18 42 L5 45 L8 32 Z"/>
      <line x1="30" y1="10" x2="40" y2="20"/>
    </svg>

    <!-- Number 8 -->
    <svg class="doodle d9" viewBox="0 0 40 60" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <circle cx="20" cy="18" r="10"/>
      <circle cx="20" cy="40" r="12"/>
    </svg>

    <!-- Triangle -->
    <svg class="doodle d10" viewBox="0 0 50 50" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="25,5 5,45 45,45"/>
    </svg>

    <!-- Equals -->
    <svg class="doodle d11" viewBox="0 0 40 30" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <line x1="8" y1="10" x2="32" y2="10"/>
      <line x1="8" y1="20" x2="32" y2="20"/>
    </svg>

    <!-- Percentage -->
    <svg class="doodle d12" viewBox="0 0 50 50" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <circle cx="15" cy="15" r="6"/>
      <circle cx="35" cy="35" r="6"/>
      <line x1="38" y1="12" x2="12" y2="38"/>
    </svg>
  </div>

  <div class="container relative z-10 w-full">
    <div class="hero-grid">
      
      <!-- Content Column -->
      <div class="hero-content pt-12 md:pt-0">
        <div class="badge glass text-primary border-primary/20 bg-white/10">
          <span class="badge-dot"></span>
          Authorized Indian Abacus Franchise Center
        </div>
        
        <h1 class="h1 mb-6 text-white text-shadow">
          Best <span class="text-gradient">Abacus Classes</span> in Trichy
        </h1>
        
        <p class="hero-lead text-white/90 mb-8 mx-auto">
          Kayal Academy provides <strong>professional abacus training in Trichy</strong>
          with world-class mental math programs for children. As an
          <span class="text-primary font-bold"><strong>Authorized Indian Abacus Franchise in Trichy</strong></span> located in
          Teppakulam, we offer Indian Abacus courses, handwriting improvement,
          phonics training, spoken Hindi classes, and CBSE/State board tuition support.
        </p>
        
        <div class="hero-actions">
          <a href="/abacus-classes-trichy/" class="btn btn-primary btn-lg shine-effect">Best Abacus Classes in Trichy</a>
          <a href="/contact/" class="btn glass-btn btn-lg">Request Callback</a>
        </div>
        
        <div class="hero-metrics glass">
          <div class="metric">
            <span class="metric-val text-gradient">3+</span>
            <span class="metric-label">Years Legacy</span>
          </div>
          <div class="metric-divider"></div>
          <div class="metric">
            <span class="metric-val text-gradient">200+</span>
            <span class="metric-label">Students Trained</span>
          </div>
          <div class="metric-divider"></div>
          <div class="metric">
            <span class="metric-val text-gradient">98%</span>
            <span class="metric-label">Pass Rate</span>
          </div>
        </div>
      </div>

      <!-- Image Column -->
      <div class="hero-visual">
        <div class="visual-wrapper">
          <Image
  src={heroImage}
  alt="Students learning abacus mental math at Kayal Academy Trichy"
  width={1200}
  height={700}
  format="webp"
  quality={80}
  class="hero-img"
  loading="eager"
/>
          <!-- Floating UI Element -->
          <div class="floating-card">
            <div class="flex items-center gap">
              <div class="icon-circle bg-emerald">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/>
                  <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/>
                  <path d="M4 22h16"/>
                  <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/>
                  <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/>
                  <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
                </svg>
              </div>
              <div>
                <div class="font-heading font-bold text-sm card-title">Awarded By Honorable School Education Minister</div>
                <div class="text-xs card-subtitle">Dr.Anbil Mahesh Poyyamozhi</div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: clamp(6rem, 15vh, 8rem) 0 clamp(2rem, 5vh, 4rem);
    min-height: 100vh;
    display: flex;
    align-items: center;
    background-color: var(--color-bg);
    overflow: hidden;
  }

  /* Ambient Glows for Modern Look */
  .glow {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    filter: blur(100px);
    z-index: 0;
    opacity: 0.4;
    animation: drift 20s infinite alternate ease-in-out;
    pointer-events: none;
  }
  
  .glow-1 {
    top: -10%;
    left: -10%;
    background: radial-gradient(circle, var(--color-primary-light) 0%, transparent 70%);
  }
  
  .glow-2 {
    bottom: -10%;
    right: -10%;
    background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);
    animation-delay: -10s;
  }

  .texture-overlay {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.02'/%3E%3C/svg%3E");
    z-index: 1;
    pointer-events: none;
  }

  /* Educational Doodles */
  .doodles-layer {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }

  .doodle {
    position: absolute;
    color: rgba(16, 185, 129, 0.04);
  }

  .d1  { width: 55px; top: 12%; left: 3%;  animation: float-doodle 18s ease-in-out infinite; }
  .d2  { width: 30px; top: 8%;  left: 48%; animation: float-doodle 22s ease-in-out infinite reverse; }
  .d3  { width: 22px; top: 55%; left: 12%; animation: float-doodle 16s ease-in-out infinite 2s; }
  .d4  { width: 24px; top: 25%; left: 35%; animation: float-doodle 20s ease-in-out infinite 4s; }
  .d5  { width: 30px; top: 70%; left: 45%; animation: float-doodle 24s ease-in-out infinite 1s; color: rgba(212, 175, 55, 0.035); }
  .d6  { width: 32px; top: 85%; left: 8%;  animation: float-doodle 19s ease-in-out infinite 3s; }
  .d7  { width: 20px; top: 40%; left: 25%; animation: float-doodle 21s ease-in-out infinite 5s; }
  .d8  { width: 28px; top: 5%;  left: 30%; animation: float-doodle 17s ease-in-out infinite 2s; color: rgba(212, 175, 55, 0.035); }
  .d9  { width: 24px; top: 65%; left: 2%;  animation: float-doodle 23s ease-in-out infinite 1s; }
  .d10 { width: 26px; top: 90%; left: 38%; animation: float-doodle 20s ease-in-out infinite 4s; }
  .d11 { width: 20px; top: 35%; left: 5%;  animation: float-doodle 18s ease-in-out infinite 3s; }
  .d12 { width: 26px; top: 80%; left: 30%; animation: float-doodle 22s ease-in-out infinite 2s; color: rgba(212, 175, 55, 0.035); }

  @keyframes float-doodle {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-12px) rotate(3deg); }
    50% { transform: translateY(-6px) rotate(-2deg); }
    75% { transform: translateY(-15px) rotate(2deg); }
  }

  @media (max-width: 1024px) {
    .doodles-layer { display: none; }
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
  }

  /* Content Styling */
  .display-text {
    font-size: clamp(3rem, 5vw, 4.5rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .text-gradient {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
  }

  .hero-lead {
    font-size: clamp(1rem, 1vh + 0.6rem, 1.05rem);
    color: var(--color-text-muted);
    margin-bottom: clamp(1.5rem, 4vh, 2.5rem);
    max-width: 540px;
    line-height: 1.7;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    font-weight: 500;
    font-size: 0.875rem;
    margin-bottom: clamp(1rem, 3vh, 2rem);
    color: var(--color-primary-dark);
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.1);
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-primary);
    display: inline-block;
    flex-shrink: 0;
    box-shadow: 0 0 6px rgba(16, 185, 129, 0.6);
    animation: dot-pulse 2s infinite;
  }

  @keyframes dot-pulse {
    0% { box-shadow: 0 0 4px rgba(16, 185, 129, 0.5); transform: scale(1); }
    50% { box-shadow: 0 0 12px rgba(16, 185, 129, 0.8), 0 0 24px rgba(16, 185, 129, 0.3); transform: scale(1.15); }
    100% { box-shadow: 0 0 4px rgba(16, 185, 129, 0.5); transform: scale(1); }
  }

  .pulsing-dot {
    width: 8px;
    height: 8px;
    background-color: var(--color-primary-light);
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
    animation: pulse 2s infinite;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: clamp(2rem, 5vh, 3rem);
  }

  .btn-lg {
    padding: 1rem 2rem;
    font-size: 1.125rem;
  }

  .glass-btn {
    background: transparent;
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    font-weight: 700;
    transition: var(--transition);
  }
  
  .glass-btn:hover {
    background: rgba(16, 185, 129, 0.1);
    transform: translateY(-2px);
  }

  .shine-effect {
    position: relative;
    overflow: hidden;
  }
  
  .shine-effect::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -60%;
    width: 20%;
    height: 200%;
    background: rgba(255,255,255,0.3);
    transform: rotate(30deg);
    transition: var(--transition);
  }

  .shine-effect:hover::after {
    left: 120%;
    transition: 0.7s ease-in-out;
  }

  /* Metrics Bar */
  .hero-metrics {
    display: inline-flex;
    align-items: center;
    gap: clamp(1rem, 3vw, 2rem);
    padding: clamp(0.75rem, 2vh, 1.25rem) clamp(1rem, 3vw, 2rem);
    border-radius: var(--radius-xl);
  }

  .metric {
    display: flex;
    flex-direction: column;
  }

  .metric-val {
    font-family: var(--font-family-heading);
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .metric-label {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .metric-divider {
    width: 2px;
    height: 40px;
    background: var(--color-border);
  }

  .hero-visual {
    position: relative;
    perspective: 1000px;
  }

  .visual-wrapper {
    position: relative;
    z-index: 2;
  }

  .hero-img {
    width: 100%;
    height: clamp(330px, 65vh, 600px);
    object-position: top;  
    object-fit: cover;
    border-radius: 2rem;
    box-shadow: 0 25px 50px -12px var(--color-shadow);
  }

  .floating-card {
  position: absolute;
  bottom: -2.5rem;
  left: -2rem;

  padding: 1rem 1.5rem;

  border-radius: var(--radius-lg);
  background: #f5f8f2ff;

  box-shadow: 0 15px 35px rgba(0,0,0,0.15);
  border: 1px solid rgba(0,255,0,0.05);

  animation: drift 6s ease-in-out infinite alternate;

  z-index: 10;

  max-width: 320px;
}
  .card-title { color: var(--color-primary-dark); }
  .card-subtitle { color: var(--color-text-muted); font-weight: 500; }

  .flex { display: flex; }
  .items-center { align-items: center; }
  .gap { gap: 1rem; }
  .icon-circle { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink:0; }
  .bg-emerald { background-color: var(--color-primary); }
  .text-sm { font-size: 0.95rem; }
  .text-xs { font-size: 0.8rem; }
  .font-heading { font-family: var(--font-family-heading); }
  .font-bold { font-weight: 700; }

  @keyframes pulse {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
  }

  @keyframes drift {
    0% { transform: translateY(0) rotate(0); }
    100% { transform: translateY(-15px) rotate(1deg); }
  }

  @media (max-width: 1024px) {
    .hero {
      padding-top: 8rem;
    }
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }
    .hero-lead {
      margin: 0 auto 2.5rem;
    }
    .hero-actions {
      justify-content: center;
    }
    .hero-img {
      height: 500px;
      margin-bottom: 1rem; /* Added margin to prevent overlapping the next section */
    }
    .floating-card {
      left: 0;
      right: 0;
      margin: 0 auto;
      bottom: -2.5rem;
      width: max-content;
      max-width: 90%;
    }
  }

  @media (max-width: 640px) {
    .hero-metrics {
      flex-direction: column;
      gap: 1rem;
      width: 100%;
    }
    .metric-divider {
      width: 100%;
      height: 2px;
    }
    .hero-actions {
      flex-direction: column;
      width: 100%;
    }
    .btn-lg { width: 100%; justify-content: center; }
  }
</style>
