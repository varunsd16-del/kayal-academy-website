---
// SummerBanner.astro - Minimal & Compact Announcement
---

<section class="summer-strip reveal">
  <div class="container strip-inner">
    <div class="strip-left">
      <span class="strip-dot"></span>
      <span class="strip-label">☀️ <strong>Summer Special Classes 2026</strong> — Admissions Open</span>
      <span class="strip-divider"></span>
      <span class="strip-courses">Abacus · Calligraphy · Vedic Maths · Hindi · Chess · Phonics</span>
    </div>
    <a href="/contact/" class="strip-cta">
      Enroll Now
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>
</section>

<style>
  .summer-strip {
    background: linear-gradient(90deg, #065f46, #059669, #10b981);
    padding: 0.85rem 0;
    position: relative;
    z-index: 5;
    overflow: hidden;
  }

  .strip-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .strip-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: white;
    font-size: 0.9rem;
    font-weight: 500;
    flex-wrap: wrap;
  }

  .strip-dot {
    width: 7px;
    height: 7px;
    background: #fbbf24;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 8px rgba(251, 191, 36, 0.6);
    animation: blink 1.5s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .strip-label {
    letter-spacing: 0.01em;
  }

  .strip-divider {
    width: 1px;
    height: 16px;
    background: rgba(255, 255, 255, 0.3);
    flex-shrink: 0;
  }

  .strip-courses {
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.85rem;
  }

  .strip-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 1.25rem;
    background: #fbbf24;
    color: #065f46;
    font-weight: 700;
    font-size: 0.82rem;
    border-radius: 100px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: all 0.3s ease;
    box-shadow: 0 2px 10px rgba(251, 191, 36, 0.25);
  }

  .strip-cta:hover {
    background: #f59e0b;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(251, 191, 36, 0.4);
  }

  @media (max-width: 768px) {
    .strip-inner {
      flex-direction: column;
      text-align: center;
      gap: 0.75rem;
    }
    .strip-left {
      justify-content: center;
      font-size: 0.82rem;
    }
    .strip-divider { display: none; }
    .strip-courses { display: none; }
  }
</style>
