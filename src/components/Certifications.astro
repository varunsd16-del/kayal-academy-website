---
// Certifications.astro - Modern Premium Design with Real Logos
const certifications = [
  {
    title: "Indian Abacus Franchise",
    authority: "Indian Abacus (IA)",
    description: "Official Authorized Franchise Center in Trichy, delivering certified mental arithmetic and brain development programs.",
    logo: "/logo/indian-abacus-authorized-franchise-logo.png",
    color: "primary",
    website: "https://indianabacus.com"
  },
  {
    title: "DBHPS Hindi Exams",
    authority: "Dakshina Bharat Hindi Prachar Sabha",
    description: "Verified Examination Center for all 8 levels of DBHPS national Hindi exams, from Parichaya to Nishnat.",
    logo: "/logo/dbhps-hindi-exams-center-logo.jfif",
    color: "accent",
    website: "https://dbhpscentral.org"
  },
  {
    title: "E Planet Learning Center",
    authority: "E Planet Educational Services",
    description: "Authorized provider for early literacy, advanced phonics, and scientifically-backed vocabulary building courses.",
    logo: "/courses/eplanet-learning-center-logo.webp",
    color: "primary",
    website: "https://eplaneteducation.com"
  },
  {
    title: "National Calligraphy Excellence",
    authority: "Rockfort Calligraphy",
    description: "Awarded for outstanding achievements and training standards in handwriting and calligraphy disciplines.",
    logo: "/achievements/logo.webp",
    color: "accent",
    link: "/achievements/Rockfort Calligraphy Certifiate.pdf"
  }
];
---

<section class="certifications section">
  <div class="container">
    <div class="text-center section-header reveal">
      <span class="badge">Official Partnerships</span>
      <h2 class="h2 reveal delay-100">Verified <span class="text-accent">Certifications</span></h2>
      <p class="subtitle text-muted reveal delay-200">
        Kayal Academy is exceptionally proud to be recognized and authorized by India's leading educational institutions.
      </p>
    </div>

    <div class="certs-grid">
      {certifications.map((cert, index) => (
        <div class={`cert-card reveal delay-${(index + 1) * 100}`}>
          <!-- Top accent bar -->
          <div class={`card-accent-bar ${cert.color === 'accent' ? 'bar-gold' : 'bar-green'}`}></div>
          
          <div class="card-body">
            <!-- Logo area -->
            <div class="logo-area">
              <div class="logo-wrapper">
                <img 
                  src={cert.logo} 
                  alt={`${cert.authority} Logo`} 
                  class="cert-logo" 
                  loading="lazy"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                />
                <div class="logo-fallback" style="display:none;">
                  <span class="fallback-text">{cert.authority.charAt(0)}</span>
                </div>
              </div>
              <div class="verified-badge">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/><path d="M9 12l2 2 4-4" fill="none" stroke="white" stroke-width="2"/></svg>
                <span>Verified</span>
              </div>
            </div>

            <!-- Content -->
            <div class="card-content">
              <h3 class="cert-title">{cert.title}</h3>
              <p class={`cert-authority ${cert.color === 'accent' ? 'auth-gold' : 'auth-green'}`}>
                {cert.authority}
              </p>
              <p class="cert-desc">{cert.description}</p>
            </div>
            
            <!-- Footer -->
            <div class="card-footer">
              {cert.link && (
                <a href={cert.link} target="_blank" rel="noopener noreferrer" class="cert-link">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                  View Certificate
                </a>
              )}
              {cert.website && (
                <a href={cert.website} target="_blank" rel="noopener noreferrer" class="cert-link">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  Visit Website
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .certifications {
    background: linear-gradient(180deg, var(--color-bg) 0%, rgba(243, 244, 246, 0.3) 100%);
    padding: 6rem 0;
    position: relative;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    font-weight: 600;
    font-size: 0.8rem;
    border-radius: var(--radius-full);
    margin-bottom: 1rem;
    border: 1px solid rgba(16, 185, 129, 0.2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(16, 185, 129, 0.08);
    color: var(--color-primary);
  }

  .section-header {
    max-width: 600px;
    margin: 0 auto 4rem;
    text-align: center;
  }

  .subtitle {
    margin-top: 1rem;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  .text-accent { color: var(--color-accent); }
  .text-muted { color: var(--color-text-muted); }
  .text-center { text-align: center; }

  .certs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.75rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .cert-card {
    position: relative;
    border-radius: 1rem;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .cert-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 50px -12px rgba(0, 0, 0, 0.12);
    border-color: rgba(16, 185, 129, 0.2);
  }

  /* Top accent bar */
  .card-accent-bar {
    height: 4px;
    width: 100%;
  }

  .bar-green {
    background: linear-gradient(90deg, #10b981, #34d399);
  }

  .bar-gold {
    background: linear-gradient(90deg, #d4af37, #f0d060);
  }

  .card-body {
    padding: 2rem 1.75rem 1.75rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  /* Logo area */
  .logo-area {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .logo-wrapper {
    width: 64px;
    height: 64px;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background: #fafafa;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cert-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 8px;
  }

  .logo-fallback {
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #10b981, #059669);
  }

  .fallback-text {
    font-size: 1.5rem;
    font-weight: 800;
    color: white;
    font-family: var(--font-family-heading);
  }

  .verified-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.65rem;
    border-radius: 100px;
    background: rgba(16, 185, 129, 0.08);
    color: #10b981;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  /* Card content */
  .card-content {
    flex-grow: 1;
  }

  .cert-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #111827;
    font-family: var(--font-family-heading);
    margin: 0 0 0.35rem;
    line-height: 1.3;
  }

  .cert-authority {
    font-size: 0.8rem;
    font-weight: 600;
    margin: 0 0 0.85rem;
    letter-spacing: 0.01em;
  }

  .auth-green { color: #10b981; }
  .auth-gold { color: #d4af37; }

  .cert-desc {
    font-size: 0.88rem;
    color: #6b7280;
    line-height: 1.65;
    margin: 0;
  }

  /* Card footer */
  .card-footer {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
  }

  .cert-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: #10b981;
    background: rgba(16, 185, 129, 0.06);
    border: 1px solid rgba(16, 185, 129, 0.15);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .cert-link:hover {
    background: #10b981;
    color: #ffffff;
    border-color: #10b981;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.25);
  }

  @media (max-width: 1100px) {
    .certs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .certs-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    .card-body {
      padding: 1.5rem;
    }
  }
</style>
