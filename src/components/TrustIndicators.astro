---
const indicators = [
  {
    title: "3+ Years",
    desc: "Educational Excellence",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" class="text-accent"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`
  },
  {
    title: "Expert Faculty",
    desc: "Certified Professionals",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" class="text-accent"><circle cx="12" cy="8" r="7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`
  },
  {
    title: "Premium Courses",
    desc: "Abacus, Calligraphy, Hindi",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" class="text-accent"><rect width="18" height="18" x="3" y="3" rx="2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M7 7h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M17 7h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M7 12h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M17 12h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M7 17h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M17 17h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`
  },
  {
    title: "North Andar St",
    desc: "Theppakulam, Trichy",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" class="text-accent"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`
  }
];
---

<section class="trust-indicators section-sm">
  <div class="container">
    <div class="indicators-grid glass">
      {indicators.map(item => (
        <div class="indicator-card">
          <div class="icon-wrapper" set:html={item.icon} />
          <div class="indicator-text">
            <h3 class="title">{item.title}</h3>
            <p class="desc">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-sm {
    padding: 0; /* Removing padding as it's pulled up */
    margin-top: -5rem;
    position: relative;
    z-index: 30; /* Increased to stay above the About section (z-index: 20) */
  }

  .indicators-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    padding: 3rem;
    border-radius: var(--radius-xl);
    box-shadow: 0 20px 40px -10px rgba(15, 118, 110, 0.1);
    background: rgba(255, 255, 255, 0.95);
  }

  .indicator-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    position: relative;
  }
  
  /* Add subtle dividers between cards except for the last one */
  .indicator-card:not(:last-child)::after {
    content: '';
    position: absolute;
    right: -1rem;
    top: 10%;
    height: 80%;
    width: 1px;
    background-color: var(--color-border);
  }

  .icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    border-radius: 50%; /* Elegant circular icons */
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.1) 0%, rgba(212, 175, 55, 0.05) 100%);
    border: 1px solid rgba(212, 175, 55, 0.2);
    flex-shrink: 0;
    transition: var(--transition);
  }
  
  .indicator-card:hover .icon-wrapper {
    transform: scale(1.1);
  }

  .text-accent { color: var(--color-accent); }

  .title {
    font-family: var(--font-family-heading);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    color: var(--color-text);
  }

  .desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-weight: 400;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .indicators-grid {
      grid-template-columns: repeat(2, 1fr);
      padding: 2rem;
    }
    .indicator-card:nth-child(2)::after { display: none; } /* Hide divider at wrap */
  }

  @media (max-width: 600px) {
    .section-sm { margin-top: -3rem; }
    .indicators-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 1.5rem;
    }
    .indicator-card::after { display: none; }
  }
</style>
