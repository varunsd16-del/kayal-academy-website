---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Programs from '../components/Programs.astro';
import Contact from '../components/Contact.astro';
---

<Layout 
  title="Handwriting & Abacus Classes Trichy | Top Tuition Centre"
  description="Explore premium Abacus and Handwriting classes in Trichy. Our Teppakulam tuition centre provides personalized coaching for all school subjects. Enroll now."
>
  <PageHeader 
    title="Abacus Classes & Skill Development Courses in Trichy"
    description="Designed for tangible results. Discover how our curriculums empower students and professionals alike to reach their highest potential."
  />
  
  <Programs />

  <!-- Detailed Course Expansion: Indian Abacus Focus -->
  <section class="section abacus-detail-section pt-0">
    <div class="container">
      <h2 class="h2 font-heading text-primary text-center mb-12">
        Best Abacus Classes in Trichy for Children
      </h2>
      
      <!-- Cognitive Benefits (Bento Style) -->
      <div class="benefits-grid mb-24 reveal">
        <div class="benefit-card text-center">
          <div class="icon-orb">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ref-icon text-accent"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/></svg>
          </div>
          <h4 class="font-heading text-lg">Whole Brain Development</h4>
          <p class="text-sm text-muted mt-2">Engages both left (logic) and right (creativity) hemispheres simultaneously through visualization.</p>
        </div>
        <div class="benefit-card text-center">
          <div class="icon-orb">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ref-icon text-accent"><path d="M11.5 2 4 14h6l-1 8 8-10h-6l1-10z"/></svg>
          </div>
          <h4 class="font-heading text-lg">Speed & Accuracy</h4>
          <p class="text-sm text-muted mt-2">Trains students to process multi-digit mental arithmetic faster than a calculator.</p>
        </div>
        <div class="benefit-card text-center">
          <div class="icon-orb">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ref-icon text-accent"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h4 class="font-heading text-lg">Photographic Memory</h4>
          <p class="text-sm text-muted mt-2">Enhances short and long-term memory via the conversion of numbers into bead images.</p>
        </div>
        <div class="benefit-card text-center">
          <div class="icon-orb">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ref-icon text-accent"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
          </div>
          <h4 class="font-heading text-lg">Laser Concentration</h4>
          <p class="text-sm text-muted mt-2">Continuous focus on the abacus tool drastically improves attention span in all subjects.</p>
        </div>
      </div>

      <!-- Curriculum Structure -->
      <div class="curriculum-structure">
        <div class="text-center mb-12 reveal">
          <span class="badge" style="background: rgba(16, 185, 129, 0.1); color: var(--color-primary); border-color: rgba(16, 185, 129, 0.2)">The Blueprint</span>
          <h2 class="h2 font-heading mt-4 text-primary">The 8-Level <span class="text-gradient">Indian Abacus</span> Structure</h2>
          <p class="text-muted max-w-2xl mx-auto mt-4">Our structured Abacus program at Kayal Academy in Teppakulam, Trichy transforms beginners into confident mental math experts through 8 progressive levels.</p>
        </div>

        <div class="levels-timeline">
          
          <div class="level-step glass reveal delay-100">
            <div class="step-marker">01-02</div>
            <h4 class="h4 font-heading text-primary">Basic Levels</h4>
            <p class="text-sm text-muted mt-2">Introduction to the Abacus tool, bead placement, values, and simple addition/subtraction. Establishing the foundation of finger movements.</p>
          </div>

          <div class="level-step glass reveal delay-200">
            <div class="step-marker">03-04</div>
            <h4 class="h4 font-heading text-primary">Intermediate Levels</h4>
            <p class="text-sm text-muted mt-2">Transition to mental visualization. Advancing into complex addition, subtraction, and the introduction of multiplication concepts.</p>
          </div>

          <div class="level-step glass reveal delay-300">
            <div class="step-marker">05-06</div>
            <h4 class="h4 font-heading text-primary">Advanced Levels</h4>
            <p class="text-sm text-muted mt-2">Mastery of multi-digit multiplication and division. Students now rely almost entirely on mental 'image flash' calculation.</p>
          </div>

          <div class="level-step glass outline-card reveal delay-400">
            <div class="step-marker accent-marker">07-08</div>
            <h4 class="h4 font-heading text-accent">Grand Master Levels</h4>
            <p class="text-sm text-muted mt-2">Complex decimals, square roots, and rapid-fire multi-row calculations. Reaching the absolute pinnacle of cognitive arithmetic speed.</p>
          </div>

        </div>

        <div class="text-center reveal" style="margin-top: 4rem;">
          <a href="/contact" class="btn btn-primary" style="padding: 1rem 2.5rem; font-size: 1.1rem; box-shadow: 0 10px 25px -5px rgba(16, 185, 129, 0.4);">
            Book Free Demo Class
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Other Premium Courses Expansion -->
  <section class="section bg-muted-light relative z-10">
    <div class="container">
      <div class="text-center mb-16 reveal delay-100">
        <span class="badge" style="background: rgba(16, 185, 129, 0.1); color: var(--color-primary); border-color: rgba(16, 185, 129, 0.2)">Comprehensive Learning</span>
        <h2 class="h2 font-heading mt-4 text-primary">Beyond <span class="text-accent">Numbers</span></h2>
        <p class="text-muted max-w-2xl mx-auto mt-4">We believe in holistic academic growth. Alongside mental arithmetic, we offer specialized programs designed to polish communication, writing skills, and core school subjects.</p>
      </div>

      <div class="other-courses-grid">
        <!-- Calligraphy & Handwriting -->
        <div class="other-course-card glass reveal delay-200">
          <div class="course-header">
            <div class="icon-orb bg-white shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="m18 5-3-3H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2"/><path d="M8 18h1"/><path d="M18.4 9.6a2 2 0 1 1 3 3L17 19l-4 1 1-4Z"/></svg>
            </div>
            <h3 class="h3 font-heading text-primary">Calligraphy & Handwriting</h3>
          </div>
          <p class="text-sm text-muted mb-6">Good handwriting is an essential mark of academic discipline. Our specialized calligraphy course focuses on ergonomic grip, letter spacing, font styles, and stroke precision, turning your child's writing into elegant art.</p>
          <ul class="text-sm feature-list text-muted">
            <li>✓ Cursive & Print Writing Styles</li>
            <li>✓ Speed Writing Improvement</li>
            <li>✓ Pencil Grip & Posture Correction</li>
            <li>✓ Good Handwriting = Better Exam Marks</li>
          </ul>
        </div>

        <!-- School Tuitions -->
        <div class="other-course-card glass reveal delay-300">
          <div class="course-header">
            <div class="icon-orb bg-white shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/><path d="M8 7h6M8 11h8M8 15h6"/></svg>
            </div>
            <h3 class="h3 font-heading text-primary">School Tuitions (1st to 8th Std)</h3>
          </div>
          <p class="text-sm text-muted mb-6">Meticulous after-school academic support for CBSE and State board students from 1st to 8th standard. We simplify complex concepts in Mathematics, Science, and Languages to ensure top-tier exam readiness.</p>
          <ul class="text-sm feature-list text-muted">
            <li>✓ 1st to 8th Standard</li>
            <li>✓ Weekly Assessment Tests</li>
            <li>✓ Doubt Clearing Sessions</li>
            <li>✓ Concept-Based Teaching</li>
          </ul>
        </div>

        <!-- Phonics -->
        <div class="other-course-card glass reveal delay-400">
          <div class="course-header">
            <div class="icon-orb bg-white shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <h3 class="h3 font-heading text-primary">Phonics Classes</h3>
          </div>
          <p class="text-sm text-muted mb-6">As an <strong class="text-accent">Authorized E Planet Learning Franchise</strong>, our phonics program employs a world-class, multi-sensory methodology to accelerate early literacy, flawless pronunciation, and spelling mastery.</p>
          <ul class="text-sm feature-list text-muted">
            <li>✓ 44 Phonics Sounds Mastery</li>
            <li>✓ Letter Sound Blending</li>
            <li>✓ Vocabulary Development</li>
            <li>✓ Reading Fluency Improvement</li>
          </ul>
        </div>

        <!-- Vedic Maths -->
        <div class="other-course-card glass reveal delay-500">
          <div class="course-header">
            <div class="icon-orb bg-white shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
            <h3 class="h3 font-heading text-primary">Vedic Maths</h3>
          </div>
          <p class="text-sm text-muted mb-6">Unlock the secrets of ancient Indian mathematics. Our Vedic Maths course equips students with powerful mental calculation techniques, enabling them to solve complex equations up to 15 times faster than traditional methods.</p>
          <ul class="text-sm feature-list text-muted">
            <li>✓ High-Speed Calculations</li>
            <li>✓ Faster Problem Solving</li>
            <li>✓ Faster Problem Solving</li>
            <li>✓ Eliminates Math Phobia</li>
          </ul>
        </div>
      </div>

      <!-- Hindi Exams Section -->
      <div class="hindi-exams-section mt-16 glass reveal delay-400">
        <div class="hindi-header text-center mb-10">
           <h3 class="h3 font-heading text-primary">Hindi Classes in Trichy (DBHPS Certified)</h3>
           <p class="text-muted text-sm mt-3 max-w-2xl mx-auto">We provide dedicated coaching for the Dakshina Bharat Hindi Prachar Sabha examinations, guiding students from absolute beginners to fluent mastery across all 8 official levels.</p>
        </div>
        
        <div class="hindi-levels-grid">
          {["Parichaya", "Prathamik", "Madhyama", "Rashtrabhasha", "Praveshika", "Visharad", "Praveen", "Nishnat"].map((exam, i) => (
            <div class="hindi-exam-badge">
              <span class="exam-number">{i + 1}</span>
              <span class="exam-name">{exam}</span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <Contact />
  <script type="application/ld+json">
{
 "@context": "https://schema.org",
 "@type": "Course",
 "name": "Indian Abacus Classes in Trichy",
 "description": "Structured 8 level Indian Abacus training program at Kayal Academy in Teppakulam, Trichy designed to improve mental math, memory and concentration in children.",
 "provider": {
   "@type": "EducationalOrganization",
   "name": "Kayal Academy",
   "url": "https://kayalacademy.com"
 },
 "educationalCredentialAwarded": "Abacus Certification",
 "courseMode": "Offline",
 "teaches": [
   "Mental Math",
   "Abacus Calculation",
   "Speed Arithmetic",
   "Brain Development"
 ]
}
</script>
</Layout>

<style>
  .abacus-detail-section {
    padding-top: 2rem;
    position: relative;
    z-index: 10;
  }
  
  /* Benefits Grid */
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .benefit-card {
    padding: 3rem 2rem;
    border-radius: var(--radius-xl);
    background: #ffffff;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(0,0,0,0.03);
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
  }

  .benefit-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 35px rgba(0,0,0,0.06);
  }

  .benefit-card h4 {
    color: #1f2937;
    font-size: 1.15rem;
  }

  .benefit-card p {
    color: #6b7280;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .icon-orb {
    margin-bottom: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: #ffffff;
    border-radius: 50%;
    border: 1.5px solid rgba(16, 185, 129, 0.2);
  }
  
  .ref-icon {
    color: #1f2937; /* Dark charcoal like the reference */
  }

  /* Levels Timeline */
  .curriculum-structure {
    padding-top: 4rem;
    border-top: 1px solid var(--color-border);
  }

  .levels-timeline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    position: relative;
  }

  .level-step {
    padding: 2.5rem 2rem;
    border-radius: var(--radius-lg);
    position: relative;
    text-align: center;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: #ffffff;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  .step-marker {
    display: inline-block;
    padding: 0.25rem 1rem;
    background: var(--color-primary);
    color: white;
    font-weight: 800;
    font-family: var(--font-family-heading);
    border-radius: var(--radius-full);
    margin-bottom: 1.5rem;
    font-size: 1.1rem;
    box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
  }

  .accent-marker {
    background: var(--color-accent);
    box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
  }

  .outline-card {
    border: 2px solid rgba(212, 175, 55, 0.4);
    background: linear-gradient(135deg, rgba(255,255,255,0.9), rgba(212, 175, 55, 0.05));
  }

  /* Typography Utilities */
  .text-primary { color: var(--color-primary); }
  .text-accent { color: var(--color-accent); }
  .text-muted { color: var(--color-text-muted); }
  .font-heading { font-family: var(--font-family-heading); }
  .text-center { text-align: center; }
  .mx-auto { margin-left: auto; margin-right: auto; }
  .mb-24 { margin-bottom: 6rem; }
  .mb-12 { margin-bottom: 3rem; }
  .mt-4 { margin-top: 1rem; }
  .mt-2 { margin-top: 0.5rem; }
  .max-w-2xl { max-width: 42rem; }

  .text-gradient {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .badge {
    display: inline-block;
    padding: 0.4rem 1.2rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-full);
    border: 1px solid transparent;
  }

  /* Other Premium Courses Expansion */
  .bg-muted-light {
    background-color: rgba(243, 244, 246, 0.5);
    border-top: 1px solid rgba(0,0,0,0.05);
  }

  .mb-16 { margin-bottom: 4rem; }
  .mt-16 { margin-top: 4rem; }
  .mb-10 { margin-bottom: 2.5rem; }
  .mt-3 { margin-top: 0.75rem; }

  .other-courses-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }

  .other-course-card {
    padding: 2.5rem 2rem;
    border-radius: var(--radius-xl);
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: #ffffff;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    transition: var(--transition);
  }

  .other-course-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px -15px rgba(16, 185, 129, 0.15);
  }

  .course-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .course-header h3 {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.3;
  }

  .course-header .icon-orb {
    margin-bottom: 0;
    width: 50px;
    height: 50px;
    flex-shrink: 0;
  }

  .feature-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .feature-list li {
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  /* Hindi Exams Area */
  .hindi-exams-section {
    padding: 3.5rem;
    border-radius: var(--radius-xl);
    border: 1px solid rgba(16, 185, 129, 0.15);
    background: #ffffff;
    box-shadow: 0 15px 40px -10px rgba(0,0,0,0.05);
  }

  .hindi-levels-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .hindi-exam-badge {
    display: flex;
    align-items: center;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0.5rem 0.5rem 0.5rem 1rem;
    transition: var(--transition);
  }

  .hindi-exam-badge:hover {
    border-color: var(--color-primary);
    background: rgba(16, 185, 129, 0.05);
    transform: translateX(3px);
  }

  .exam-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: var(--color-primary-light);
    color: white;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 800;
    margin-right: 1rem;
    flex-shrink: 0;
  }

  .exam-name {
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.9rem;
    letter-spacing: 0.02em;
  }

  @media (max-width: 1024px) {
    .benefits-grid, .levels-timeline { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .other-courses-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .hindi-levels-grid { grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  }

  @media (max-width: 768px) {
    .benefits-grid, .levels-timeline, .other-courses-grid { grid-template-columns: 1fr; }
    .level-step { text-align: left; display: flex; flex-direction: column; align-items: flex-start; }
    .hindi-levels-grid { grid-template-columns: 1fr; gap: 0.75rem; }
    .hindi-exams-section { padding: 1.5rem; }
    .hindi-exam-badge { padding: 0.5rem; }
    .exam-name { font-size: 0.85rem; }
    .other-course-card { padding: 1.5rem; }
  }

  @media (min-width: 480px) and (max-width: 768px) {
    .hindi-levels-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
