---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SummerBanner from '../components/SummerBanner.astro';
import PhotoBento from '../components/PhotoBento.astro';
import TrustIndicators from '../components/TrustIndicators.astro';
import AboutMe from '../components/AboutMe.astro';
import Methodology from '../components/Methodology.astro';
import Programs from '../components/Programs.astro';
import Testimonials from '../components/Testimonials.astro';
import TrustFoundation from '../components/TrustFoundation.astro';
import Contact from '../components/Contact.astro';
---

<Layout
  title="Abacus Classes in Trichy | Mental Math Training | Kayal Academy"
  description="Kayal Academy — Trichy's top abacus training centre for children aged 5–14. Authorized Indian Abacus franchise in Teppakulam. Also offering phonics, Vedic maths, Hindi & calligraphy. Book a free demo today."
  ogTitle="Best Abacus Classes in Trichy | Kayal Academy"
  ogDescription="Join 200+ students at Kayal Academy, Teppakulam. Expert abacus training, phonics, Vedic maths & Hindi classes for children aged 5–14. Authorized Indian Abacus franchise in Trichy."
>

  <!-- FIX: sr-only H1 kept exactly as-is — good for SEO -->
  <h1 class="sr-only">
    Best Abacus Classes in Trichy – Kayal Academy Mental Math Training
  </h1>

  <Fragment slot="head">
    <link rel="preload" as="image" href="/achievements/abacus-training-trichy-hero.webp" />
  </Fragment>

  <Hero />
  <SummerBanner />
  <PhotoBento />
  <TrustIndicators />
  <TrustFoundation />
  <AboutMe />
  <Methodology />
  <Programs buttonText="View Full Curriculum" buttonLink="/courses/" />
  <Testimonials />
  <Contact />

  <!--
    FIX: Removed the duplicate FAQPage schema that was here.
    Reason: A homepage FAQPage schema is wrong — Google expects FAQ schema
    only on pages that actually display Q&A content (i.e. /faq).
    The correct FAQPage schema is already injected by Layout.astro
    when Astro.url.pathname === '/faq'.

    The LocalBusiness + EducationalOrganization schema in Layout.astro
    already covers the homepage fully.
  -->

</Layout>