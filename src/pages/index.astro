---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SummerBanner from '../components/SummerBanner.astro';
import PhotoBento from '../components/PhotoBento.astro';
import TrustIndicators from '../components/TrustIndicators.astro';
import AboutMe from '../components/AboutMe.astro';
import Methodology from '../components/Methodology.astro';
import Programs from '../components/Programs.astro';
