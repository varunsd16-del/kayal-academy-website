---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
---

<Layout 
  title="Handwriting & Calligraphy Classes in Trichy | Improve Writing Speed"
  description="Transform your child's handwriting with Kayal Academy's specialized classes in Trichy. We focus on legibility, speed, and artistic calligraphy. Perfect for school students."
>
  <PageHeader 
    title="Handwriting & Calligraphy Classes"
    description="Empower your child with the gift of elegant and legible writing. Our certified trainers help correct grip, posture, and letter formation for lasting results."
  />

  <section class="section writing-detail-section">
    <div class="container">
      <div class="grid-2 gap-12 items-center">
        <div class="reveal reveal-left relative">
          <div class="image-stack">
            <img src="/courses/calligraphy-handwriting-classes-trichy.webp" alt="Handwriting classes at Kayal Academy Trichy" class="main-img rounded-xl shadow-2xl" />
            <div class="accent-frame"></div>
          </div>
        </div>
        <div class="reveal reveal-right">
          <span class="badge mb-4">Skill Development</span>
          <h2 class="h2 mb-6">Master the Art of <span class="text-accent">Beautiful Writing</span></h2>
          <div class="prose text-muted">
            <p>In a world dominated by digital screens, the ability to write clearly and beautifully remains a critical academic and personal skill. Good handwriting is not just about aesthetics; it boosts a child's confidence and directly impacts their exam marks.</p>
            <p>Our curriculum at Kayal Academy is designed to correct common writing issues and introduce students to the sophisticated world of calligraphy.</p>
          </div>
          <div class="stats-row mt-8">
            <div class="stat-item">
              <span class="stat-num">100%</span>
              <span class="stat-label">Legibility Rate</span>
            </div>
            <div class="stat-item">
              <span class="stat-num">30%</span>
              <span class="stat-label">Faster Speed</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-dark text-white overflow-hidden">
    <div class="container relative z-10">
      <div class="text-center mb-16 reveal">
        <h2 class="h2 font-heading text-white">Our Specialized <span class="text-primary-light">Modules</span></h2>
        <p class="text-white opacity-80 mt-4 max-w-2xl mx-auto">From correcting basic pencil grips to mastering complex calligraphy strokes.</p>
      </div>

      <div class="modules-grid">
        {[
          { 
            title: "Grip & Posture Correction", 
            desc: "Correcting ergonomic issues to prevent hand fatigue and improve control.", 
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-light"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>` 
          },
          { 
            title: "Cursive Mastery", 
            desc: "Developing smooth, connected, and rhythmic cursive writing for better speed.", 
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-light"><path d="M12 3c7.2 0 9 1.8 9 9s-1.8 9-9 9-9-1.8-9-9 1.8-9 9-9Z"/><path d="M7 14c2 0 3-1 3-3s-1-2-3-2"/><path d="M11 9c2 0 3 1 3 3s-1 2-3 2"/><path d="M15 14c2 0 3-1 3-3s-1-2-3-2"/></svg>` 
          },
          { 
            title: "Print Script Clarity", 
            desc: "Ensuring every letter is distinct and legible, ideal for formal examinations.", 
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-light"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h10"/><path d="M7 12h10"/><path d="M7 17h10"/></svg>` 
          },
          { 
            title: "Artistic Calligraphy", 
            desc: "Introduction to broad-edged and pointed pen calligraphy styles for creative expression.", 
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-light"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-1.5"/><path d="M14 17l-1.5-1.5"/><path d="m2 22 5-5"/><path d="M9 5.8a2.4 2.4 0 1 0 0-4.8 2.4 2.4 0 0 0 0 4.8z"/><path d="M12.7 13.5a2.5 2.5 0 1 0-3.5-3.5"/></svg>` 
          }
        ].map((module, i) => (
          <div class="module-card glass-dark reveal delay-${i * 100}">
            <div class="module-icon" set:html={module.icon}></div>
            <h4 class="h4 font-heading text-white mb-3">{module.title}</h4>
            <p class="text-sm text-white opacity-80">{module.desc}</p>
          </div>
        ))}
      </div>
    </div>
    <div class="bg-decoration"></div>
  </section>

  <div class="testimonial-wrapper">
    <Testimonials />
  </div>

  <Contact />

</Layout>

<style>
  .writing-detail-section {
    padding: 6rem 0;
  }
  
  .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .items-center { align-items: center; }

  .main-img {
    width: 100%;
    height: auto;
    z-index: 2;
    position: relative;
  }

  .accent-frame {
    position: absolute;
    bottom: -2rem;
    left: -2rem;
    width: 80%;
    height: 80%;
    background: var(--color-primary-light);
    border-radius: 1.5rem;
    z-index: 1;
    opacity: 0.1;
  }

  .stats-row {
    display: flex;
    gap: 3rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
  }

  .stat-num {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-weight: 600;
    margin-top: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .bg-dark {
    background: #064e3b; /* Deep emerald matching global theme */
    padding: 6rem 0;
    position: relative;
    color: white; /* Force text to white for entire section */
  }

  .bg-dark h2, 
  .bg-dark h4 {
    color: white !important;
  }

  .bg-dark p {
    color: rgba(255, 255, 255, 0.8) !important;
  }

  .module-icon {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    color: var(--color-primary-light); /* Neon mint icons */
  }

  .glass-dark {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 2.25rem 2rem;
    border-radius: 1.5rem;
    transition: all 0.3s ease;
  }

  .glass-dark:hover {
    background: rgba(16, 185, 129, 0.1); /* Neon minty green hover tint */
    border-color: var(--color-primary-light);
    transform: translateY(-8px);
    box-shadow: 0 20px 40px -10px rgba(16, 185, 129, 0.2);
  }

  .modules-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .bg-decoration {
    position: absolute;
    top: 0;
    right: 0;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .testimonial-wrapper {
    background-color: var(--color-bg);
    padding-top: 2rem;
  }

  @media (max-width: 1024px) {
    .modules-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .grid-2 { grid-template-columns: 1fr; gap: 3rem; }
    .modules-grid { grid-template-columns: 1fr; }
    .stats-row { justify-content: center; }
  }
</style>
